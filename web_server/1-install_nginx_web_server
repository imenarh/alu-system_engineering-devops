#!/usr/bin/env bash
# Installs and configures Nginx to return "Holberton School" at root

apt-get update -y
apt-get install -y nginx
echo "Holberton School" | sudo tee /var/www/html/index.html > /dev/null
echo "Holberton School" | sudo tee /var/www/html/index.nginx-debian.html > /dev/null
service nginx restart
